{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "name": "@hyperpolymath/nextgen-languages-evangeliser",
  "version": "0.6.0-alpha",
  "license": "MPL-2.0",
  "exports": "./bin/evangeliser.js",
  "tasks": {
    "build": "deno run -A --no-lock scripts/validate-cartridges.js",
    "validate": "deno run -A --no-lock scripts/validate-cartridges.js",
    "gui": "deno run --allow-read --allow-net gui/server.js",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "test": "deno run --allow-read test/run_all.js",
    "pre-commit": "deno task lint && deno task fmt --check"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": false,
    "singleQuote": false,
    "proseWrap": "preserve",
    "include": ["bin/", "gui/", "scripts/", "src/cartridges.js", "test/run_all.js", "deno.json"]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
